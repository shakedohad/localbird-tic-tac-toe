{
  "name": "localbird-tic-tac-toe",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w @localbird/server\" \"npm run dev -w @localbird/client\"",
    "dev:server": "npm run dev -w @localbird/server",
    "dev:client": "npm run dev -w @localbird/client",
    "build:client": "npm run build -w @localbird/client",
    "build": "npm run build:client",
    "start:server": "npm run start -w @localbird/server",
    "start": "npm run start:server",
    "prod": "npm run build && npm run start",
    "verify": "npx tsc --noEmit && npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "concurrently": "^9.2.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
