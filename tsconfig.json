{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "server/domain/**/*.ts",
    "server/contracts/**/*.ts",
    "server/application/**/*.ts",
    "server/**/*.ts"
  ]
}
